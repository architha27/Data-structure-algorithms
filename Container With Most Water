class Solution {
    public int maxArea(int[] height) {
        int l=0;
        int r=height.length-1;
        int max=0;
        int ca=0;
        while(l<r){
            ca=Math.min(height[l],height[r])*(r-l);
            max=Math.max(ca,max);
            if(height[l]>height[r]){
                r--;
            }else{
                l++;
            }
        } return max;
        
    }
}
